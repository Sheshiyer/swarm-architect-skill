{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Swarm Architect Issue Mapping",
  "type": "object",
  "required": [
    "task_id",
    "issue_title",
    "phase",
    "wave",
    "swarm",
    "area",
    "owner_agent",
    "owner_role",
    "dependencies",
    "branch",
    "worktree",
    "deliverable",
    "acceptance",
    "validation"
  ],
  "properties": {
    "task_id": { "type": "string" },
    "issue_title": { "type": "string" },
    "phase": { "type": "string" },
    "wave": { "type": "string" },
    "swarm": { "type": "string" },
    "area": {
      "type": "string",
      "enum": ["frontend", "backend", "data", "infra", "qa", "product"]
    },
    "owner_agent": { "type": "string" },
    "owner_role": { "type": "string" },
    "labels": {
      "type": "array",
      "items": { "type": "string" }
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" }
    },
    "branch": { "type": "string" },
    "worktree": { "type": "string" },
    "lock_zone_files": {
      "type": "array",
      "items": { "type": "string" }
    },
    "deliverable": { "type": "string" },
    "acceptance": { "type": "string" },
    "validation": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["planned", "ready", "blocked", "in-progress", "in-review", "done"]
    }
  },
  "additionalProperties": false
}
